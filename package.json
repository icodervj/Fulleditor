{
  "name": "lightweight-editor",
  "version": "1.0.0",
  "description": "A lightweight, framework-free WYSIWYG editor for the browser.",
  "license": "MIT",
  "main": "editor.js",
  "style": "dist/editor.min.css",
  "unpkg": "dist/editor.min.js",
  "jsdelivr": "dist/editor.min.js",
  "files": [
    "editor.js",
    "editor.css",
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist && mkdir -p dist",
    "build:js": "terser editor.js -c -m -o dist/editor.min.js",
    "build:css": "cleancss -o dist/editor.min.css editor.css",
    "build": "npm run clean && npm run build:js && npm run build:css",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "editor",
    "wysiwyg",
    "rich-text",
    "javascript",
    "contenteditable"
  ],
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.39.0"
  }
}